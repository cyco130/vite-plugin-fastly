{
  "name": "vite-plugin-fastly-workspace-root",
  "private": "true",
  "scripts": {
    "dev": "pnpm -r --parallel --filter \"./packages/*\" run dev",
    "build": "pnpm -r --filter \"./packages/*\" run build",
    "prepare": "husky install",
    "precommit": "lint-staged",
    "format": "oxfmt",
    "ci": "pnpm -r --stream run ci",
    "test": "pnpm run /^test:/",
    "test:packages": "pnpm -r --stream run test",
    "test:format": "oxfmt --check"
  },
  "dependencies": {
    "kill-em-all": "link:../kill-em-all/packages/kill-em-all"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "oxfmt": "^0.36.0",
    "typescript": "^5.9.3"
  }
}
