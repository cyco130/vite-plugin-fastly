{
  "name": "vite-plugin-fastly",
  "version": "0.1.0",
  "description": "vite-plugin-fastly",
  "keywords": [
    "compute-at-edge",
    "edge-computing",
    "fastly",
    "fastly-compute",
    "serverless",
    "viceroy",
    "vite",
    "vite-plugin"
  ],
  "license": "MIT",
  "repository": "github:cyco130/vite-plugin-fastly",
  "files": [
    "dist",
    "*.d.ts"
  ],
  "type": "module",
  "typesVersions": {
    "*": {
      "*": [
        "dist/*.d.ts"
      ]
    }
  },
  "exports": {
    ".": "./dist/plugin.js",
    "./runner": "./dist/runner.js",
    "./types": "./types.d.ts"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "prepack": "rm -rf dist && pnpm build",
    "test": "pnpm run /^test:/",
    "test:typecheck": "tsc -p tsconfig.json --noEmit",
    "test:lint": "eslint . --max-warnings 0 --ignore-pattern dist --no-warn-ignored",
    "test:package": "publint"
  },
  "dependencies": {
    "http-proxy-3": "^1.23.2",
    "kill-em-all": "0.0.5"
  },
  "devDependencies": {
    "@cyco130/eslint-config": "^7.0.0",
    "@fastly/cli": "^14.2.0",
    "@fastly/js-compute": "^3.40.1",
    "@types/node": "^25.0.7",
    "eslint": "^10.1.0",
    "publint": "^0.3.18",
    "tsdown": "0.21.7",
    "typescript": "^6.0.2",
    "vite": "8.0.3"
  },
  "peerDependencies": {
    "@fastly/js-compute": "3",
    "vite": "~7.3 || 8"
  }
}
